    <button
      id="themeToggle"
      class="theme-toggle"
      onclick="toggleTheme()"
      aria-label="Switch to dark mode"
    >
      <span class="icon-moon">☾</span>
      <span class="icon-sun">☀</span>
    </button>
    <button class="nav-hamburger" id="navHamburger" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>
