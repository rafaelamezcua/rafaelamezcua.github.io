---
import { Image } from 'astro:assets';
import meImg from '../assets/images/Me.JPG';
import bartImg from '../assets/images/Bart.jpg';
import clothesImg from '../assets/images/Clothes.jpg';
---

<section id="projects">
  <div class="container">
    <p class="s-label fade-in">Selected Work</p>
    <h2 class="s-title fade-in">Projects & Branding</h2>
    <div class="s-divider fade-in"></div>
    <div class="proj-grid">

      <!-- Intertwine Fitness -->
      <div class="proj-card fade-in">
        <div class="proj-thumb if">
          <div class="if-mockup">
            <div class="if-logo-mark">
              <span class="if-letters">IF</span>
            </div>
            <div class="if-swatches">
              <div class="if-swatch" style="background:#0d6e4f;" title="Terra Green"></div>
              <div class="if-swatch" style="background:#12a372;" title="Accent Green"></div>
              <div class="if-swatch" style="background:#c8a870;" title="Gold"></div>
              <div class="if-swatch" style="background:#0a1f15;" title="Dark"></div>
            </div>
            <div class="if-tagline">Intertwine Fitness · Brand Identity</div>
          </div>
        </div>
        <div class="proj-body">
          <div class="proj-tags">
            <span class="tag">Brand Identity</span>
            <span class="tag">Logo Design</span>
            <span class="tag">Illustrator</span>
            <span class="tag">In Progress</span>
          </div>
          <div class="proj-title">Intertwine Fitness</div>
          <p class="proj-desc">
            <strong>Problem:</strong> A local fitness brand had no visual identity — no logo, no color system, no way to stand out in a crowded market.<br/>
            <strong>Built:</strong> Designed the full brand identity from scratch — wordmark, logo system, color palette, and typography — using Illustrator with a focus on strength, connectivity, and movement.<br/>
            <strong>Result:</strong> A cohesive, production-ready brand system currently in active development for launch.
          </p>
        </div>
      </div>

      <!-- Cycle Care -->
      <div class="proj-card fade-in">
        <div class="proj-thumb cc">
          <div class="carousel-track" id="carousel-cc">
            <div class="carousel-slide">
              <Image src={meImg} alt="Cycle Care event" width={600} height={400} quality={80} loading="eager" style="object-position:center 30%;" />
            </div>
            <div class="carousel-slide">
              <Image src={bartImg} alt="Cycle Care volunteer" width={600} height={400} quality={80} style="object-position:center 30%;" />
            </div>
            <div class="carousel-slide">
              <Image src={clothesImg} alt="Cycle Care clothing collection" width={600} height={400} quality={80} style="object-position:center 1%;" />
            </div>
          </div>
          <button class="carousel-btn prev" onclick="moveCarousel('cc',-1)">&#8249;</button>
          <button class="carousel-btn next" onclick="moveCarousel('cc',1)">&#8250;</button>
          <div class="carousel-dots" id="dots-cc">
            <div class="dot active" onclick="goToSlide('cc',0)"></div>
            <div class="dot" onclick="goToSlide('cc',1)"></div>
            <div class="dot" onclick="goToSlide('cc',2)"></div>
          </div>
        </div>
        <div class="proj-body">
          <div class="proj-tags">
            <span class="tag">Sustainability</span>
            <span class="tag">Campaign Strategy</span>
            <span class="tag">Marketing</span>
          </div>
          <div class="proj-title">Cycle Care</div>
          <p class="proj-desc">
            <strong>Problem:</strong> Textile waste at community colleges goes largely unaddressed — students discard clothing with no sustainable alternative.<br/>
            <strong>Built:</strong> Founded and led Cycle Care at SDCC — developed the brand strategy, messaging framework, outreach materials, and coordinated collection events to drive community participation.<br/>
            <strong>Result:</strong> Measurable community impact documented in a formal impact report, with student engagement across campus.
          </p>
          <a
            href="/docs/Winnie and Rafael Final Impact Report.pdf"
            target="_blank"
            style="display:inline-block;margin-top:1rem;background:var(--terra);color:var(--cream);padding:0.5rem 1.2rem;border-radius:0.4rem;font-size:0.82rem;font-weight:700;text-decoration:none;"
          >View Impact Report →</a>
        </div>
      </div>

      <!-- Nymbus -->
      <div class="proj-card wide fade-in">
        <div class="proj-thumb" style="background:linear-gradient(135deg,#e8e8f4,#f0eeff);height:240px;display:flex;align-items:center;justify-content:center;padding:2rem;gap:2rem;position:relative;overflow:hidden;">
          <div style="flex:1;max-width:480px;">
            <div style="background:#fff;border:1px solid #ddd;border-radius:12px;overflow:hidden;box-shadow:0 8px 32px rgba(127,119,221,0.15);">
              <!-- Browser chrome -->
              <div style="background:#f5f5f7;padding:8px 14px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid #e8e8e8;">
                <div style="display:flex;gap:5px;">
                  <div style="width:9px;height:9px;border-radius:50%;background:#ff5f57;"></div>
                  <div style="width:9px;height:9px;border-radius:50%;background:#febc2e;"></div>
                  <div style="width:9px;height:9px;border-radius:50%;background:#28c840;"></div>
                </div>
                <div style="display:flex;align-items:center;gap:6px;background:#ebebeb;border-radius:6px;padding:3px 10px;">
                  <img src="/nymbus-logo.png" style="width:13px;height:13px;border-radius:3px;" alt="Nymbus" />
                  <span style="font-size:10px;color:#555;font-weight:600;">nymbus.pro</span>
                </div>
                <div style="width:60px;"></div>
              </div>
              <!-- Stats row -->
              <div style="padding:12px 14px 8px;display:grid;grid-template-columns:repeat(3,1fr);gap:6px;">
                <div style="background:#f8f7ff;border:1px solid #e8e6ff;border-radius:8px;padding:8px 10px;">
                  <div style="font-size:8px;color:#aaa;text-transform:uppercase;margin-bottom:3px;letter-spacing:0.05em;">Applications</div>
                  <div id="nymbus-stat-total" style="font-size:18px;font-weight:800;color:#7f77dd;">—</div>
                </div>
                <div style="background:#fffbf0;border:1px solid #f0e8cc;border-radius:8px;padding:8px 10px;">
                  <div style="font-size:8px;color:#aaa;text-transform:uppercase;margin-bottom:3px;letter-spacing:0.05em;">Interviews</div>
                  <div id="nymbus-stat-interviews" style="font-size:18px;font-weight:800;color:#d4a847;">—</div>
                </div>
                <div style="background:#f0f8ff;border:1px solid #cce0f5;border-radius:8px;padding:8px 10px;">
                  <div style="font-size:8px;color:#aaa;text-transform:uppercase;margin-bottom:3px;letter-spacing:0.05em;">Users</div>
                  <div id="nymbus-stat-users" style="font-size:18px;font-weight:800;color:#6a9fd8;">Live</div>
                </div>
              </div>
              <!-- Table preview rows -->
              <div style="padding:0 14px 10px;display:flex;flex-direction:column;gap:4px;">
                <div style="display:flex;align-items:center;gap:8px;padding:5px 8px;background:#fafafa;border-radius:6px;border-left:3px solid #d4a847;">
                  <div style="width:20px;height:20px;border-radius:5px;background:#7f77dd;display:flex;align-items:center;justify-content:center;font-size:8px;font-weight:bold;color:#fff;flex-shrink:0;">P</div>
                  <span style="font-size:10px;color:#333;font-weight:600;flex:1;">Precisely</span>
                  <span style="font-size:9px;color:#6a9fd8;background:#e8f2fc;border-radius:10px;padding:1px 7px;">interview</span>
                </div>
                <div style="display:flex;align-items:center;gap:8px;padding:5px 8px;background:#fafafa;border-radius:6px;border-left:3px solid #5aad6a;">
                  <div style="width:20px;height:20px;border-radius:5px;background:#5aad6a;display:flex;align-items:center;justify-content:center;font-size:8px;font-weight:bold;color:#fff;flex-shrink:0;">M</div>
                  <span style="font-size:10px;color:#333;font-weight:600;flex:1;">Mercury Health</span>
                  <span style="font-size:9px;color:#5aad6a;background:#e8f5ec;border-radius:10px;padding:1px 7px;">offer</span>
                </div>
              </div>
            </div>
          </div>
          <!-- Live badge -->
          <div style="position:absolute;top:14px;right:14px;display:flex;align-items:center;gap:5px;background:rgba(90,173,106,0.12);border:1px solid rgba(90,173,106,0.3);border-radius:20px;padding:4px 10px;">
            <div style="width:6px;height:6px;border-radius:50%;background:#5aad6a;box-shadow:0 0 0 0 rgba(90,173,106,0.4);animation:pulse-dot 1.5s infinite;"></div>
            <span style="font-size:10px;font-weight:700;color:#5aad6a;letter-spacing:0.05em;">LIVE</span>
          </div>
        </div>
        <div class="proj-body">
          <div class="proj-tags">
            <span class="tag">Full-Stack</span>
            <span class="tag">Node.js</span>
            <span class="tag">PostgreSQL</span>
            <span class="tag">JavaScript</span>
            <span class="tag">PWA</span>
            <span class="tag">REST API</span>
            <span class="tag">Deployed</span>
          </div>
          <div class="proj-title" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;">
            Nymbus
            <a
              href="https://nymbus.pro"
              target="_blank"
              style="font-size:0.78rem;font-weight:700;color:var(--terra);text-decoration:none;border:1px solid rgba(13,110,79,0.3);padding:0.25rem 0.8rem;border-radius:0.3rem;transition:all 0.2s;"
              onmouseover="this.style.background='rgba(13,110,79,0.1)'"
              onmouseout="this.style.background='transparent'"
            >View Live →</a>
          </div>
          <p class="proj-desc">
            <strong>Problem:</strong> Tracking job applications in a spreadsheet meant losing context, missing follow-ups, and no visibility into your pipeline.<br/>
            <strong>Built:</strong> A full-stack PWA with Node.js/Express, PostgreSQL, JWT auth with email verification, Kanban board, interview calendar, analytics dashboard, CSV export, and a bookmarklet for one-click saving from any job board.<br/>
            <strong>Result:</strong> Launched to real users — tracking <span id="nymbus-desc-total">hundreds of</span> applications across the platform.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  @keyframes pulse-dot {
    0% { box-shadow: 0 0 0 0 rgba(90,173,106,0.4); }
    70% { box-shadow: 0 0 0 6px rgba(90,173,106,0); }
    100% { box-shadow: 0 0 0 0 rgba(90,173,106,0); }
  }
</style>

<script is:inline>
  (function () {
    fetch('https://nymbus.pro/stats/public')
      .then(r => r.json())
      .then(data => {
        const total = data.total || 0;
        const interviews = data.interviews || 0;
        const el = document.getElementById('nymbus-stat-total');
        const eli = document.getElementById('nymbus-stat-interviews');
        const eld = document.getElementById('nymbus-desc-total');
        if (el) el.textContent = total.toLocaleString();
        if (eli) eli.textContent = interviews.toLocaleString();
        if (eld) eld.textContent = total.toLocaleString();
      })
      .catch(() => {});
  })();
</script>
