---
import { Image } from 'astro:assets';
import meImg from '../assets/images/Me.JPG';
import bartImg from '../assets/images/Bart.jpg';
import clothesImg from '../assets/images/Clothes.jpg';
---

<section id="projects">
  <div class="container">
    <p class="s-label fade-in">Selected Work</p>
    <h2 class="s-title fade-in">Projects & Branding</h2>
    <div class="s-divider fade-in"></div>

    <!-- Tab bar -->
    <div class="proj-tabs fade-in">
      <button class="proj-tab active" onclick="switchTab('nymbus', this)">
        <span class="proj-tab-num">01</span>
        <span class="proj-tab-name">Nymbus</span>
        <span class="proj-tab-type">Full-Stack App</span>
      </button>
      <button class="proj-tab" onclick="switchTab('intertwine', this)">
        <span class="proj-tab-num">02</span>
        <span class="proj-tab-name">Intertwine Fitness</span>
        <span class="proj-tab-type">Brand & Web</span>
      </button>
      <button class="proj-tab" onclick="switchTab('cyclecare', this)">
        <span class="proj-tab-num">03</span>
        <span class="proj-tab-name">Cycle Care</span>
        <span class="proj-tab-type">Campaign</span>
      </button>
    </div>

    <!-- Spotlight panels -->
    <div class="proj-spotlight fade-in">

      <!-- Nymbus -->
      <div class="proj-panel active" id="panel-nymbus">
        <div class="proj-panel-img nymbus-video-pane">
          <iframe
            src="https://www.youtube.com/embed/vLtpZwADpdE?rel=0&modestbranding=1&color=white"
            title="Nymbus promo video"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
        <div class="proj-panel-info">
          <div class="proj-tags">
            <span class="tag">Full-Stack</span>
            <span class="tag">Node.js</span>
            <span class="tag">PostgreSQL</span>
            <span class="tag">JavaScript</span>
            <span class="tag">PWA</span>
            <span class="tag">Deployed</span>
          </div>
          <div class="proj-panel-title">Nymbus</div>
          <p class="proj-desc">
            <strong>Problem:</strong> Tracking job applications in a spreadsheet meant losing context, missing follow-ups, and no visibility into your pipeline.<br/><br/>
            <strong>Built:</strong> A full-stack PWA with Node.js/Express, PostgreSQL, JWT auth, Kanban board, interview calendar, analytics dashboard, CSV export, and a bookmarklet for one-click saving from any job board.<br/><br/>
            <strong>Result:</strong> Launched to real users — tracking <span id="nymbus-desc-total">hundreds of</span> applications across the platform.
          </p>
          <a href="https://nymbus.pro" target="_blank" class="proj-cta">View Live →</a>
        </div>
      </div>

      <!-- Intertwine Fitness -->
      <div class="proj-panel" id="panel-intertwine">
        <div class="proj-panel-img if-panel-img" id="if-carousel">
          <img id="if-slide-img" src="/if-brand-intro.svg" alt="Brand Introduction" />
          <button class="carousel-btn prev" onclick="moveIF(-1)">&#8249;</button>
          <button class="carousel-btn next" onclick="moveIF(1)">&#8250;</button>
          <div class="carousel-dots" id="if-dots">
            <div class="dot active" onclick="goIF(0)"></div>
            <div class="dot" onclick="goIF(1)"></div>
            <div class="dot" onclick="goIF(2)"></div>
          </div>
        </div>
        <div class="proj-panel-info">
          <div class="proj-tags">
            <span class="tag">Brand Identity</span>
            <span class="tag">Logo Design</span>
            <span class="tag">Web Design</span>
            <span class="tag">Illustrator</span>
          </div>
          <div class="proj-panel-title">Intertwine Fitness</div>
          <p class="proj-desc">
            <strong>Problem:</strong> A local fitness brand had no visual identity — no logo, no color system, no way to stand out in a crowded market.<br/><br/>
            <strong>Built:</strong> Designed the full brand identity from scratch — wordmark, logo system, color palette, and typography — using Illustrator with a focus on strength, connectivity, and movement.<br/><br/>
            <strong>Result:</strong> A cohesive, production-ready brand system currently live at intertwinefitness.com.
          </p>
          <a href="https://www.intertwinefitness.com" target="_blank" class="proj-cta">View Site →</a>
        </div>
      </div>

      <!-- Cycle Care -->
      <div class="proj-panel" id="panel-cyclecare">
        <div class="proj-panel-img cc-panel-img">
          <div class="carousel-track" id="carousel-cc">
            <div class="carousel-slide">
              <Image src={meImg} alt="Cycle Care event" width={800} height={500} quality={80} loading="eager" style="object-position:center 30%;" />
            </div>
            <div class="carousel-slide">
              <Image src={bartImg} alt="Cycle Care volunteer" width={800} height={500} quality={80} style="object-position:center 30%;" />
            </div>
            <div class="carousel-slide">
              <Image src={clothesImg} alt="Cycle Care clothing" width={800} height={500} quality={80} style="object-position:center 1%;" />
            </div>
          </div>
          <button class="carousel-btn prev" onclick="moveCarousel('cc',-1)">&#8249;</button>
          <button class="carousel-btn next" onclick="moveCarousel('cc',1)">&#8250;</button>
          <div class="carousel-dots" id="dots-cc">
            <div class="dot active" onclick="goToSlide('cc',0)"></div>
            <div class="dot" onclick="goToSlide('cc',1)"></div>
            <div class="dot" onclick="goToSlide('cc',2)"></div>
          </div>
        </div>
        <div class="proj-panel-info">
          <div class="proj-tags">
            <span class="tag">Sustainability</span>
            <span class="tag">Campaign Strategy</span>
            <span class="tag">Marketing</span>
          </div>
          <div class="proj-panel-title">Cycle Care</div>
          <p class="proj-desc">
            <strong>Problem:</strong> Textile waste at community colleges goes largely unaddressed — students discard clothing with no sustainable alternative.<br/><br/>
            <strong>Built:</strong> Founded and led Cycle Care at SDCC — developed the brand strategy, messaging framework, outreach materials, and coordinated collection events to drive participation.<br/><br/>
            <strong>Result:</strong> Measurable community impact documented in a formal impact report, with student engagement across campus.
          </p>
          <a href="/docs/Winnie and Rafael Final Impact Report.pdf" target="_blank" class="proj-cta">View Impact Report →</a>
        </div>
      </div>

    </div>
  </div>
</section>

<script is:inline>
  function switchTab(id, btn) {
    document.querySelectorAll('.proj-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.proj-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    var panel = document.getElementById('panel-' + id);
    if (panel) panel.classList.add('active');
  }

  var ifSlides = [
    { src: '/if-brand-intro.svg',  alt: 'Brand Introduction',              ratio: '1080/1350' },
    { src: '/if-redesign.svg',     alt: 'Website Redesign Announcement',   ratio: '1080/1350' },
    { src: '/if-1.png',            alt: 'Intertwine Fitness',              ratio: '1871/1147' },
  ];
  var ifIdx = 0;

  function goIF(idx) {
    ifIdx = idx;
    var carousel = document.getElementById('if-carousel');
    var img = document.getElementById('if-slide-img');
    if (!carousel || !img) return;
    img.style.opacity = '0';
    setTimeout(function () {
      var slide = ifSlides[ifIdx];
      img.src = slide.src;
      img.alt = slide.alt;
      carousel.style.aspectRatio = slide.ratio;
      img.style.opacity = '1';
      document.querySelectorAll('#if-dots .dot').forEach(function (d, i) {
        d.classList.toggle('active', i === ifIdx);
      });
    }, 190);
  }

  function moveIF(dir) {
    goIF((ifIdx + dir + ifSlides.length) % ifSlides.length);
  }

  (function () {
    fetch('https://nymbus.pro/stats/public')
      .then(r => r.json())
      .then(data => {
        var el = document.getElementById('nymbus-desc-total');
        if (el) el.textContent = (data.total || 0).toLocaleString();
      })
      .catch(() => {});
  })();
</script>
